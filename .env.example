# ============================================
# Moi-Kursi Configuration
# ============================================
# ВАЖНО: Скопируй этот файл как .env и заполни своими данными
# Important: Copy this file as .env and fill with your credentials
# НИКОГДА не коммитируй реальный .env в Git!

# ============================================
# Beget Database (MySQL)
# ============================================
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=username_moikursi

# ============================================
# Beget FTP (для загрузки файлов)
# ============================================
FTP_HOST=your-domain.beget.com
FTP_USER=your_ftp_login
FTP_PASS=your_ftp_password
FTP_PORT=21

# Куда загружать файлы на FTP (обычно public_html)
FTP_REMOTE_PATH=/public_html

# ============================================
# Mail.ru Cloud (для видео)
# ============================================
MAILRU_EMAIL=your.email@mail.ru
MAILRU_PASSWORD=your_mailru_password

# ID папки в Mail.ru Cloud где хранятся видео
# (если используешь API, нужен токен)
MAILRU_FOLDER_ID=0

# ============================================
# Локальные пути к файлам
# ============================================
# Путь к папке с видео на локальном диске
LOCAL_VIDEOS_PATH=D:/videos

# Путь к проекту
PROJECT_PATH=D:/С раб.стола/Мои документы/Projects/Moi-kursi

# ============================================
# Опции деплоя
# ============================================
# Автоматически создавать таблицы БД?
AUTO_CREATE_TABLES=true

# Автоматически загружать видео на Mail.ru Cloud?
AUTO_UPLOAD_VIDEOS=false

# ============================================
# API Configuration (GitHub Pages + VPS)
# ============================================
# Frontend на GitHub Pages
FRONTEND_BASE_URL=https://desyatovaelena11.github.io/moi-kursi/

# Backend на VPS (nip.io домен для разработки)
API_BASE_URL=https://155.212.139.51.nip.io/backend/api/v1

# Для продакшена можешь использовать свой домен
# API_BASE_URL=https://your-domain.ru/backend/api/v1
